# ── Priya Voice Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# OpenAI
OPENAI_API_KEY=sk-...

# Sarvam AI (STT + TTS)
SARVAM_API_KEY=...
SARVAM_VOICE=priya

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# GPT model for intent classification
GPT_MODEL=gpt-4o-mini

# TTS tuning
TTS_PACE=1.20
TTS_TEMP=0.85
TTS_MODEL=bulbul:v3

# Speech detection tuning
SILENCE_THRESH=500
ECHO_COOLDOWN=0.8

# Google Sheets logging
GSHEET_ID=your_google_sheet_id_here
GSHEET_CREDS=gsheet_credentials.json
GSHEET_TAB=ShelarTVS_Bikes_General_LeadForm_v2

# Greeting timing
GREETING_LEAD_IN=1.3
